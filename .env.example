# Open Video — Environment Configuration
# Copy this file to .env and adjust values.

# Server port
OV_SERVER_PORT=7456

# Daemon URL (agents use this to reach the server)
OV_DAEMON_URL=http://localhost:7456

# Data directory for SQLite and project files
# Default: .ov/ and projects/ under project root
# OV_DATA_DIR=.ov

# HyperFrames CLI path (optional, defaults to npx hyperframes)
# HYPERFRAMES_BIN=npx hyperframes

# Media: allow stub/placeholder renders (for testing without real providers)
# OV_MEDIA_ALLOW_STUBS=0
