{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://code2mp4.com/schemas/storyboard.schema.json",
  "title": "Storyboard",
  "description": "HOW each scene looks and moves. Generated by the Director Agent from brief + script.",
  "type": "object",
  "required": ["title", "duration", "aspectRatio", "scenes"],
  "properties": {
    "title": { "type": "string" },
    "duration": { "type": "number", "minimum": 5 },
    "aspectRatio": { "type": "string", "enum": ["16:9", "9:16", "1:1", "4:5"] },
    "motionSystem": { "type": "string", "enum": ["editorial", "tech", "warm-soft", "cinematic", "brutalist", "neon", "orbital", "organic"] },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["id", "number", "duration", "goal", "visual", "text", "motion"],
        "properties": {
          "id": { "type": "string", "description": "Unique scene identifier (kebab-case)" },
          "number": { "type": "number", "minimum": 1, "description": "Sequential scene position" },
          "duration": { "type": "number", "minimum": 2, "maximum": 30 },
          "goal": { "type": "string", "description": "What this scene communicates" },
          "visual": { "type": "string", "description": "Visual description — background, layout, elements" },
          "text": { "type": "string", "description": "On-screen text" },
          "motion": { "type": "string", "description": "Animation description" },
          "audio": { "type": ["string", "null"], "description": "Audio cue or null" }
        }
      }
    }
  }
}
