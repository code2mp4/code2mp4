{
  "name": "code2mp4",
  "version": "0.1.0",
  "private": true,
  "description": "AI-driven video production — Open Design meets HyperFrames. Describe a video and an AI coding agent writes, animates, and renders it to MP4.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/openvideo-ai/openvideo",
  "repository": {
    "type": "git",
    "url": "https://github.com/openvideo-ai/openvideo.git"
  },
  "bugs": {
    "url": "https://github.com/openvideo-ai/openvideo/issues"
  },
  "keywords": [
    "video",
    "ai",
    "agent",
    "hyperframes",
    "motion-graphics",
    "animation",
    "gsap",
    "mp4",
    "video-production",
    "open-design",
    "claude-code",
    "opencode",
    "typescript",
    "nextjs",
    "express"
  ],
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @code2mp4/tools-dev build && node tools/dev/dist/c2m-dev.js start",
    "start": "pnpm --filter @code2mp4/server build && node apps/server/dist/server.js",
    "typecheck": "pnpm -r --if-present run typecheck",
    "build": "pnpm -r --if-present run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "npx oxlint --quiet apps/ packages/ tools/ 2>/dev/null || true",
    "format": "npx oxfmt apps/ packages/ tools/ 2>/dev/null || true",
    "status": "node tools/dev/dist/c2m-dev.js status",
    "stop": "node tools/dev/dist/c2m-dev.js stop"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@hyperframes/player": "^0.4.43",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "oxlint": "^1.62.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  }
}
